<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.FantasyPT" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/fpt_accent</item>
        <item name="colorPrimaryVariant">@color/fpt_accent_dark</item>
        <item name="colorOnPrimary">@color/fpt_on_accent</item>
        <item name="colorSecondary">@color/fpt_accent</item>
        <item name="colorSecondaryVariant">@color/fpt_accent_dark</item>
        <item name="colorOnSecondary">@color/fpt_on_accent</item>

        <item name="android:windowBackground">@color/fpt_bg</item>
        <item name="colorSurface">@color/fpt_surface</item>
        <item name="colorOnSurface">@color/fpt_text</item>
        <item name="android:textColorPrimary">@color/fpt_text</item>
        <item name="android:textColorSecondary">@color/fpt_text_muted</item>

        <item name="android:statusBarColor" tools:targetApi="l">@color/fpt_accent_dark</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/fpt_bg</item>

        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.FantasyPT.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.FantasyPT.MediumComponent</item>
    </style>

    <style name="ShapeAppearance.FantasyPT.SmallComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.FantasyPT.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
</resources>
